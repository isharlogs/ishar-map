        "69083": {
          "vnum": 69083,
          "name": "Village Center",
          "description": "Ambling through the village, you walk out into a grassy clearing that serves as a community center for the hobbits of Ingeen. Four paths converge in the clearing, one leading from a group of huts to the north, another from a magnificent building to the southeast, a third from a two- story hut to the south, and the fourth from beneath a gargantuan oak tree to the west.",
